
(rules PCB mz-2000
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout off)
    (eu.mihosoft.freerouting.autoroute on)
    (postroute on)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 5418)
    (layer_rule F.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 2.2)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 1.8)
    )
  )
  (rule
    (width 200.0)
    (clear 200.2)
    (clear 100.0 (type smd_to_turn_gap))
    (clear 50.0 (type smd_smd))
  )
  (padstack "Via[0-1]_500:300_um"
    (shape
      (circle F.Cu 500.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 500.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_500:300_um" "Via[0-1]_500:300_um" default
  )
  (via 
    "Via[0-1]_500:300_um-kicad_default" "Via[0-1]_500:300_um" "kicad_default"
  )
  (via 
    "Via[0-1]_500:300_um-+5V" "Via[0-1]_500:300_um" +5V
  )
  (via 
    "Via[0-1]_500:300_um-GND" "Via[0-1]_500:300_um" GND
  )
  (via_rule
    default "Via[0-1]_500:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_500:300_um-kicad_default"
  )
  (via_rule
    +5V "Via[0-1]_500:300_um-+5V"
  )
  (via_rule
    GND "Via[0-1]_500:300_um-GND"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    +5V GND /D2 /D1 /D0 /A7 /A6 /A5
    /A4 /A3 /A2 /A1 /A0 /D3 /D4 /D5
    /D6 /D7 /~WR /~RD /~IOREQ /RESET /MISO /MOSI
    /SCK /CS "Net-(U1-Pad6)" "Net-(U1-Pad12)" "Net-(U1-Pad4)" "Net-(U1-Pad10)" "Net-(U1-Pad2)" "Net-(U1-Pad8)"
    "Net-(U10-Pad6)" "Net-(U10-Pad1)" "Net-(U10-Pad21)" "Net-(U10-Pad2)" "Net-(U10-Pad22)" "Net-(U10-Pad3)" "Net-(U10-Pad23)" "Net-(U10-Pad4)"
    "Net-(U10-Pad24)" "Net-(U10-Pad25)" "Net-(U10-Pad10)" "Net-(U10-Pad16)" "Net-(U10-Pad18)" "Net-(U10-Pad19)" "Net-(U10-Pad20)" /A15
    /A14 /A13 /A12 /A11 /A10 /A9 /A8 /~MREQ
    /~EXWAIT "Net-(J3-Pad26)" "Net-(J3-Pad25)" "Net-(J3-Pad11)" "Net-(J3-Pad10)" "Net-(J3-Pad9)" "Net-(J4-Pad1)" "Net-(J4-Pad2)"
    "Net-(J4-Pad3)"
    (clearance_class "kicad_default")
    (via_rule kicad_default)
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class +5V
    (clearance_class +5V)
    (via_rule +5V)
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class GND
    (clearance_class GND)
    (via_rule GND)
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)